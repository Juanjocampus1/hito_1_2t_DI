---
const {title, text} = Astro.props
---

<div class="flex flex-col items-center justify-center shadow-2xl py-8 px-8">
    <h1 class="text-4xl font-bold text-center text-[#ff7e5f]">
        {title}
    </h1>

    <div>
        <p class="text-black">
            {text}
        </p>
    </div>
</div>